## No gear code -- corresponds to EM for Spanish ELL -- remove the records
FL_STD_DATA_SPECIES_TABLE[is.na(REPORTING_QUALITY) & is.na(GEAR_CODE), .N, .(YEAR, FLEET_CODE, GEAR_CODE, FISHING_GROUND_CODE)]
# Save the data without any gear
